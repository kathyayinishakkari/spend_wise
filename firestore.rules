rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
      match /expenses/{expenseId} { allow read, write: if isOwner(uid); }
      match /budgets/{budgetId} { allow read, write: if isOwner(uid); }
      match /reimbursements/{reimbursementId} { allow read, write: if isOwner(uid); }
      match /settlements/{settlementId} { allow read, write: if isOwner(uid); }
      match /settings/{settingId} { allow read, write: if isOwner(uid); }
    }
  }
}